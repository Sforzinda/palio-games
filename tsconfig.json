{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "react": ["../cassa-palio/node_modules/@types/react"],
      "react/jsx-runtime": ["../cassa-palio/node_modules/@types/react/jsx-runtime"],
      "react-dom": ["../cassa-palio/node_modules/@types/react-dom"],
      "react-router-dom": ["../cassa-palio/node_modules/react-router-dom"],
      "lucide-react": ["../cassa-palio/node_modules/lucide-react"],
      "@supabase/supabase-js": ["../cassa-palio/node_modules/@supabase/supabase-js"]
    },

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
